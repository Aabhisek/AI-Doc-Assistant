# ── Maven build output ────────────────────────────────────────────────────────
target/
!**/src/main/**/target/
!**/src/test/**/target/
*.class
*.jar
*.war
*.ear
.mvn/wrapper/maven-wrapper.jar

# ── Spring Boot / Java ────────────────────────────────────────────────────────
*.log
*.log.*
logs/
spring-shell.log
HELP.md

# Local override properties (never commit local secrets via properties files)
application-local.properties
application-local.yml
src/main/resources/application-local.properties
src/main/resources/application-local.yml

# ── Secrets & API keys ────────────────────────────────────────────────────────
.env
.env.*
!.env.example
!.env.template
*.pem
*.key
*.p12
*.jks

# ── Uploaded user files ───────────────────────────────────────────────────────
uploads/

# ── Frontend (React / Node) ───────────────────────────────────────────────────
frontend/node_modules/
frontend/dist/
frontend/.cache/
frontend/.vite/
frontend/coverage/
frontend/.env
frontend/.env.*
!frontend/.env.example

# ── IDE — IntelliJ IDEA ───────────────────────────────────────────────────────
.idea/
*.iws
*.iml
*.ipr

# ── IDE — VS Code ─────────────────────────────────────────────────────────────
.vscode/

# ── IDE — Eclipse / STS ───────────────────────────────────────────────────────
.apt_generated
.classpath
.factorypath
.project
.settings/
.springBeans
.sts4-cache/

# ── IDE — NetBeans ────────────────────────────────────────────────────────────
/nbproject/private/
/nbbuild/
/dist/
/nbdist/
/.nb-gradle/
build/
!**/src/main/**/build/
!**/src/test/**/build/

# ── IDE — Cursor ──────────────────────────────────────────────────────────────
.cursor/

# ── macOS ─────────────────────────────────────────────────────────────────────
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
.AppleDouble
.LSOverride

# ── Windows ───────────────────────────────────────────────────────────────────
Thumbs.db
ehthumbs.db
Desktop.ini
$RECYCLE.BIN/

# ── Linux ─────────────────────────────────────────────────────────────────────
*~

# ── Temp / OS scratch ─────────────────────────────────────────────────────────
*.tmp
*.swp
*.swo
*.bak

# ── Personal / interview notes ────────────────────────────────────────────────
INTERVIEW_TALKING_POINTS.md

# ── Local documentation (kept locally, not in repo) ──────────────────────────
docs/
